# Flask 环境
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# 大模型配置
DEFAULT_MODEL=deepseek
TEMPERATURE=0.7
MAX_TOKENS=2048

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_MODEL=deepseek-chat

# 通义千问（可选）
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-plus

# 火山引擎 TTS（可选。去 console.volcengine.com 开通语音合成获取）
VOLCANO_TTS_APP_ID=
VOLCANO_TTS_TOKEN=

# 腾讯云 TTS（可选。去 console.cloud.tencent.com 开通语音合成获取）
TENCENT_TTS_SECRET_ID=
TENCENT_TTS_SECRET_KEY=

# 数据库 (MySQL)
DATABASE_URL=mysql+pymysql://root:Zhang20.@localhost:3306/smart_assistant

# Redis（可选）
REDIS_URL=redis://localhost:6379/0

# 限流
RATE_LIMIT=60
